# Copia a .env y completa los valores (no subas .env al repositorio).
# Local: DEBUG=True. En el servidor de deploy: DEBUG=False y ALLOWED_HOSTS con el dominio del API.
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=postgres
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
# Supabase/producción: require. Postgres local sin SSL: disable o vacío.
DB_SSLMODE=require

FRONTEND_URL=http://localhost:5173
# Orígenes del front (CORS). En producción añade la URL https del front.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
GOOGLE_OAUTH_CLIENT_ID=

RESEND_API_KEY=
DEFAULT_FROM_EMAIL=SIGIBARF <onboarding@resend.dev>
